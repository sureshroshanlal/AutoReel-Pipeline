# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# INSTAGRAM_ACCESS_TOKEN: Optional. Facebook Graph API access token for Instagram Reels publishing.
INSTAGRAM_ACCESS_TOKEN=

# YOUTUBE_API_KEY: Optional. Youtube Data API Key (v3) to pull structured video info automatically.
YOUTUBE_API_KEY=

# FIREWORKS_API_KEY: Required for real Whisper transcription + localization (AMD Developer Hackathon)
FIREWORKS_API_KEY=

# FFMPEG_PATH: Optional. Path to your ffmpeg binary. Defaults to "ffmpeg" (resolved from PATH).
# Set this if ffmpeg isn't on your PATH, e.g. "C:\ffmpeg\bin\ffmpeg.exe" on Windows.
FFMPEG_PATH=

# YTDLP_PATH: Optional. Path to your yt-dlp binary. Defaults to "yt-dlp.exe" in the project root.
# Set this to "yt-dlp" (or a full path) if you installed it elsewhere / via a package manager.
YTDLP_PATH=
